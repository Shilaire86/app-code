# Client-side runtime env for Expo / EAS.
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Stripe price IDs (web checkout) ──────────────────────────────────────────
# Find these in: Stripe Dashboard → Products → Prices
# Monthly plans
EXPO_PUBLIC_STRIPE_PRICE_ID_STANDARD=price_standard_monthly
EXPO_PUBLIC_STRIPE_PRICE_ID_VIP=price_vip_monthly
EXPO_PUBLIC_STRIPE_PRICE_ID_ELITE=price_elite_monthly
# Annual plans
EXPO_PUBLIC_STRIPE_PRICE_ID_STANDARD_ANNUAL=price_standard_annual
EXPO_PUBLIC_STRIPE_PRICE_ID_VIP_ANNUAL=price_vip_annual
EXPO_PUBLIC_STRIPE_PRICE_ID_ELITE_ANNUAL=price_elite_annual

# ── RevenueCat SDK keys (native billing) ─────────────────────────────────────
# Find these in: RevenueCat Dashboard → Project → API Keys
EXPO_PUBLIC_RC_APPLE_KEY=appl_your_apple_revenuecat_key
EXPO_PUBLIC_RC_GOOGLE_KEY=goog_your_google_revenuecat_key

# Set to true ONLY after the RevenueCat → Supabase webhook is fully configured.
# Leaving this false disables native billing to avoid stale subscription state.
EXPO_PUBLIC_NATIVE_BILLING_SYNC_ENABLED=false

# ── Supabase Edge Function secrets ────────────────────────────────────────────
# These are NOT set here — they must be set in the Supabase dashboard:
#   Project Settings → Edge Functions → Secrets
#
# Required secrets for create-checkout-session and stripe-webhook:
#   STRIPE_SECRET_KEY              sk_live_... (or sk_test_... for testing)
#   STRIPE_WEBHOOK_SECRET          whsec_...
#   STRIPE_PRICE_ID_STANDARD       price_... (monthly)
#   STRIPE_PRICE_ID_VIP            price_... (monthly)
#   STRIPE_PRICE_ID_ELITE          price_... (monthly)
#   STRIPE_PRICE_ID_STANDARD_ANNUAL price_... (annual)
#   STRIPE_PRICE_ID_VIP_ANNUAL     price_... (annual)
#   STRIPE_PRICE_ID_ELITE_ANNUAL   price_... (annual)
#
# SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are
# auto-injected by Supabase into edge functions — no manual secret needed.

# ── EAS build secrets ─────────────────────────────────────────────────────────
# For production builds, set all EXPO_PUBLIC_* values above as EAS secrets:
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_URL --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_STRIPE_PRICE_ID_STANDARD --value "..."
#   ... (repeat for all EXPO_PUBLIC_* variables)
